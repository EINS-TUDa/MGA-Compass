    "capacity": {
      "path": "data/installed_capacity.pkl",
      "dims": ["index", "technology"]
    },
    "generation": {
      "path": "data/generation_over_snapshots.pkl",
      "dims": ["index", "snapshot", "technology"]
    }
  },
  "plots": {
    "generation": {
      "type": "stacked_timeseries",
      "dataset": "generation",
      "x_dim": "snapshot",
      "categories_dim": "technology"
    },
    "capacity": {
      "type": "bar",
      "dataset": "capacity",
      "x_dim": "technology"
    },
    "total generation": {
      "type": "timeseries",
      "dataset": "generation",
      "x_dim": "snapshot"
    }
  }
